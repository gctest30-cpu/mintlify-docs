  "keyFeatures": [
    "JWT-based authentication with access and refresh tokens",
    "User registration via email or username",
    "User search by name",
    "Post creation with title, content, visibility, media attachments, and hashtags",
    "Post comments with create, edit, and delete",
    "Post likes and dislikes",
    "Post sharing with optional comment",
    "Direct messaging between users",
    "Notifications for likes, comments, follows, and messages",
    "User profiles with avatar, bio, location, and website"
  ],
  "publicApiSurface": [
    "GET /ping",
    "POST /signup",
    "POST /signin",
    "GET /user",
    "GET /search-by-name",
    "POST /{user}/new-post",
    "GET /{user}/find-post",
    "PUT /{user}/{post}/edit-post",
    "DELETE /{user}/{post}/delete-post",
    "POST /{user}/{post}/comment-post",
    "GET /{user}/{post}/comments",
    "PUT /{user}/{post}/{comment}/comment-edit",
    "DELETE /{user}/{post}/{comment}/comment-delete",
    "POST /{user}/{post}/{comment}/like",
    "POST /{user}/{post}/{comment}/dislike",
    "POST /{user}/{post}/share",
    "PUT /{user}/{share}/unshare"
  ]
}
